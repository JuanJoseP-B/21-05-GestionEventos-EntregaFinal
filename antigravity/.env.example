SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Desarrollo (SQLite)
DATABASE_URL=sqlite:///db.sqlite3

# Producción (PostgreSQL) — descomentar y configurar
# DATABASE_URL=postgres://user:password@localhost:5432/antigravity_db

# Email — consola en desarrollo
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Email — producción SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=Antigravity <noreply@antigravity.com>
